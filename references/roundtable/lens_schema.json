{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collab-master-skill/references/roundtable/lens_schema.json",
  "title": "LensTable lens card 契约（v1.5 v0.1）",
  "$comment": "每张 lens 卡的机器契约。validate.py lenses 命令用它校验 lenses.yaml 的每个 card。治理：lensName(id) 是受控 enum，单一真源 = lens_registry(本目录 lenses.yaml 的 id 集)。与 frameworkName 重叠的 id 必须同拼写(连字符)，并标 reuses_framework:true。新增 lens = 先进 registry，再写卡。category in [politics/ethics/eastern] 的卡 safety_boundary 必填。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "core_question", "sees", "ignores", "default_moves", "attack_questions", "output_obligation"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "$comment": "kebab-case；与 frameworkName 重叠时必须同 id" },
    "name": { "type": "string" },
    "category": { "enum": ["epistemology", "systems", "economics", "politics", "ethics", "psychology", "design", "engineering", "aesthetics", "eastern"] },
    "reuses_framework": { "type": "boolean", "$comment": "true 表示该 id 同时是 frameworkName enum 成员" },
    "core_question": { "type": "string" },
    "sees": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "ignores": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "default_moves": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "attack_questions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "output_obligation": { "type": "array", "minItems": 1, "items": { "type": "string" }, "$comment": "反 cosplay 核心：session 输出对不上这些 → 没真用镜头 = 无效" },
    "compatible_with": { "type": "array", "items": { "type": "string" }, "$comment": "引用完整性：每个 id 必须 ∈ registry" },
    "conflicts_with": { "type": "array", "items": { "type": "string" } },
    "evidence_preference": { "type": "array", "items": { "type": "string" } },
    "safety_boundary": { "type": "array", "items": { "type": "string" } }
  },
  "if": { "properties": { "category": { "enum": ["politics", "ethics", "eastern"] } } },
  "then": { "required": ["safety_boundary"] }
}
